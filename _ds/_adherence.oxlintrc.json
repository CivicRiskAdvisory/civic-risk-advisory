{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "brand.constants.js",
              "components/brand/**",
              "components/content/**",
              "components/layout/**",
              "components/media/**",
              "ui_kits/one_pagers/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Serif|IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Serif, IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccentStripe'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|side|style|key|ref|className|style|children)$/]",
        "message": "<AccentStripe> doesn't accept that prop. Declared props: width, side, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccentStripe'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<AccentStripe> side must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bullet'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|style|key|ref|className|style|children)$/]",
        "message": "<Bullet> doesn't accept that prop. Declared props: label, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|href|tone|style|key|ref|className|style|children)$/]",
        "message": "<ContactLine> doesn't accept that prop. Declared props: type, label, href, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactLine'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:email|phone|linkedin)$/]",
        "message": "<ContactLine> type must be one of 'email' | 'phone' | 'linkedin'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactLine'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<ContactLine> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<FooterBar> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeaderContact'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|href|key|ref|className|style|children)$/]",
        "message": "<HeaderContact> doesn't accept that prop. Declared props: type, label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeaderContact'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:email|phone|linkedin)$/]",
        "message": "<HeaderContact> type must be one of 'email' | 'phone' | 'linkedin'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Headshot'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|initials|size|ring|alt|style|key|ref|className|style|children)$/]",
        "message": "<Headshot> doesn't accept that prop. Declared props: src, initials, size, ring, alt, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BridgeMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|height|title|style|key|ref|className|style|children)$/]",
        "message": "<BridgeMark> doesn't accept that prop. Declared props: tone, height, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BridgeMark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<BridgeMark> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|as|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: children, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|as|style|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: tone, size, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Wordmark> tone must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Wordmark> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WritingCredit'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|source|style|key|ref|className|style|children)$/]",
        "message": "<WritingCredit> doesn't accept that prop. Declared props: children, source, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
